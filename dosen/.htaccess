<IfModule mod_rewrite.c>
RewriteEngine On

# Block direct access to all PHP files except login.php and dosen_proses_login.php
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteCond %{REQUEST_FILENAME} !login\.php$
RewriteCond %{REQUEST_FILENAME} !dosen_proses_login\.php$
RewriteCond %{REQUEST_FILENAME} !dosen_proses_simpan_materi\.php$
RewriteCond %{REQUEST_FILENAME} !dosen_proses_simpan_bukti_pembelajaran\.php$
RewriteCond %{REQUEST_FILENAME} !dosen_konfirm\.php$
RewriteCond %{REQUEST_FILENAME} !dosen_hapus_jurnal\.php$
RewriteRule ^(.*)$ - [F,L]

# Allow index.php to handle all requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Disable directory listing
Options -Indexes
